# ═══════════════════════════════════════════════════════════════════════════════
# SWU_OSR — Backup Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Architecture:
#   Production Server ──rclone push──▶ Google Drive ◀──rclone pull── VPS
#
# Google Drive is the central hub. Both production and VPS connect to it
# via rclone. No SSH keys needed between servers.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Local Paths ───────────────────────────────────────────────────────────────
# Where backups are stored locally (inside Docker volume or bind mount)
BACKUP_LOCAL_DIR=/backups

# Project root (for docker compose commands)
PROJECT_DIR=/opt/swu_osr

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_CONTAINER=swu_osr-postgres-1
PG_USER=postgres
PG_DB=swu_osr

# ── Retention ─────────────────────────────────────────────────────────────────
# How many full base backups to keep (each ~50-100MB)
RETAIN_FULL_COUNT=2

# How many days of WAL segments to keep
RETAIN_WAL_DAYS=14

# How many days of upload snapshots to keep
RETAIN_UPLOADS_DAYS=14

# ── Google Drive (rclone) ────────────────────────────────────────────────────
# This is the ONLY remote destination. VPS pulls from here too.
# Setup: ./backup/setup-gdrive.sh
GDRIVE_ENABLED=true
GDRIVE_REMOTE=gdrive
GDRIVE_PATH=SWU_OSR_Backups
RCLONE_CONFIG=/root/.config/rclone/rclone.conf
