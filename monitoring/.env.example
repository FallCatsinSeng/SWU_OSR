# ==============================================================================
# SWU OSR Platform - Monitoring Stack Environment Variables
# ==============================================================================
# Copy file ini ke .env di direktori root sebelum menjalankan monitoring stack:
#   cp monitoring/.env.example .env.monitoring
#   source .env.monitoring  # atau export manual
#
# Cara set ke shell:
#   export GRAFANA_ADMIN_PASSWORD=$(openssl rand -base64 24)
#
# Cara jalankan monitoring stack:
#   GRAFANA_ADMIN_PASSWORD=xxx docker compose -f docker-compose.monitoring.yml up -d
# ==============================================================================

# Grafana admin password — WAJIB diisi, jangan gunakan nilai default lemah
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-random-password
